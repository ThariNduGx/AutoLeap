                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"update_id\": 1001,\n  \"message\": {\n    \"message_id\": 123,\n    \"from\": { \n      \"id\": 781380219, \n      \"first_name\": \"Judge\" \n    },\n    \"chat\": { \n      \"id\": 781380219, \n      \"type\": \"private\" \n    },\n    \"text\": \"Hello, is anyone there?\",\n    \"date\": 1700000000\n  }\n}"
                        },
